{
  "name": "prosemirror-suggestcat-plugin",
  "version": "2.2.3",
  "description": "AI-powered grammar checking, text completion, and prompt-based editing for ProseMirror",
  "main": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "module": "dist/index.es.js",
  "source": "src/index.ts",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "rollup -c --bundleConfigAsCjs",
    "dev": "rollup -c -w --bundleConfigAsCjs",
    "format": "eslint src --ext .ts --fix",
    "lint": "tsc --noEmit && eslint src --ext .ts",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "e2e:server:completeV2": "vite --config e2e/completeV2/vite.config.ts",
    "e2e:server:grammarV2": "vite --config e2e/grammarSuggestV2/vite.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emergence-engineering/emergence-tools.git",
    "directory": "packages/prosemirror-suggestcat-plugin"
  },
  "files": [
    "dist/**/*"
  ],
  "author": "Emergence Engineering",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/emergence-engineering/emergence-tools/issues"
  },
  "homepage": "https://github.com/emergence-engineering/emergence-tools/tree/main/packages/prosemirror-suggestcat-plugin#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@emergence-engineering/fast-diff-merge": "workspace:*",
    "@emergence-engineering/prosemirror-block-runner": "workspace:*",
    "@emergence-engineering/prosemirror-text-map": "workspace:*",
    "fast-diff": "^1.3.0",
    "lodash.debounce": "^4.0.8"
  },
  "peerDependencies": {
    "prosemirror-model": "^1.19.3",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.7.3",
    "prosemirror-view": "^1.31.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/jest": "^29.5.1",
    "@types/lodash.debounce": "^4.0.7",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "eslint": "^8.29.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jest": "^27.1.6",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prosemirror-example-setup": "^1.2.2",
    "prosemirror-model": "^1.19.3",
    "prosemirror-schema-basic": "^1.2.2",
    "prosemirror-state": "^1.4.3",
    "prosemirror-test-builder": "^1.1.1",
    "prosemirror-transform": "^1.7.3",
    "prosemirror-view": "^1.31.4",
    "rimraf": "^6.0.1",
    "rollup": "^3.7.4",
    "rollup-plugin-copy": "^3.4.0",
    "rollup-plugin-minification": "^0.2.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-typescript2": "^0.35.0",
    "ts-jest": "^29.1.0",
    "tslib": "^2.6.1",
    "typescript": "^5.1.6",
    "vite": "^5.0.0"
  }
}
