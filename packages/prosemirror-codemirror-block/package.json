{
  "name": "prosemirror-codemirror-block",
  "version": "0.5.9",
  "description": "ProseMirror CodeMirror code block plugin",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "rollup -c --bundleConfigAsCjs",
    "dev": "rollup -c -w --bundleConfigAsCjs",
    "format": "eslint src --ext .ts --fix",
    "prepublishOnly": "npm run build && npm test && npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags",
    "lint": "tsc --noEmit && eslint src --ext .ts",
    "test": "echo \"no test specified\" && exit 0",
    "upgrade-interactive": "npm-check --update",
    "publish:np": "np"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/emergence-engineering/prosemirror-codemirror-block.git"
  },
  "files": [
    "dist/**/*"
  ],
  "author": "Emergence Engineering",
  "keywords": [
    "ProseMirror",
    "CodeMirror",
    "code_block",
    "plugin"
  ],
  "license": "ISC",
  "bugs": {
    "url": "https://gitlab.com/emergence-engineering/prosemirror-codemirror-block/issues"
  },
  "homepage": "https://gitlab.com/emergence-engineering/prosemirror-codemirror-block#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.9.1",
    "@codemirror/commands": "^6.2.5",
    "@codemirror/lang-cpp": "^6.0.2",
    "@codemirror/lang-css": "^6.2.1",
    "@codemirror/lang-html": "^6.4.6",
    "@codemirror/lang-java": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.1",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-lezer": "^6.0.1",
    "@codemirror/lang-markdown": "^6.2.1",
    "@codemirror/lang-php": "^6.0.1",
    "@codemirror/lang-python": "^6.1.3",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-sql": "^6.5.4",
    "@codemirror/lang-wast": "^6.0.1",
    "@codemirror/lang-xml": "^6.0.2",
    "@codemirror/language": "^6.3.1",
    "@codemirror/legacy-modes": "^6.3.3",
    "@codemirror/search": "^6.5.4",
    "@codemirror/view": "^6.7.1",
    "@lezer/common": "^1.0.2"
  },
  "peerDependencies": {
    "@codemirror/state": "^6.1.4",
    "prosemirror-commands": "^1.5.0",
    "prosemirror-model": "^1.18.3",
    "prosemirror-state": "^1.4.2",
    "prosemirror-view": "^1.29.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "eslint": "^8.49.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.33.2",
    "np": "^8.0.4",
    "npm-check": "^6.0.1",
    "prettier": "^2.8.1",
    "rollup": "^3.29.2",
    "rollup-plugin-minification": "^0.2.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-typescript2": "^0.35.0",
    "typescript": "^5.2.2"
  }
}
