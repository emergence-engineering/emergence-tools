{
  "name": "@emergence-engineering/prosemirror-multi-editor-diff",
  "version": "0.1.0",
  "description": "Multi-editor diff visualization for ProseMirror — compare two editors side-by-side with inline diff decorations, spacer synchronization, and node pairing",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "rollup -c --bundleConfigAsCjs",
    "dev": "rollup -c -w --bundleConfigAsCjs",
    "format": "eslint src --ext .ts --fix",
    "lint": "tsc --noEmit",
    "test": "jest"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emergence-engineering/emergence-tools.git",
    "directory": "packages/prosemirror-multi-editor-diff"
  },
  "files": [
    "dist/**/*"
  ],
  "author": "Emergence Engineering",
  "keywords": [
    "ProseMirror",
    "diff",
    "multi-editor",
    "comparison",
    "decorations"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/emergence-engineering/emergence-tools/issues"
  },
  "homepage": "https://github.com/emergence-engineering/emergence-tools/tree/main/packages/prosemirror-multi-editor-diff#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@emergence-engineering/prosemirror-text-map": "workspace:*",
    "@emergence-engineering/prosemirror-block-runner": "workspace:*",
    "diff": "^5.1.0",
    "string-similarity-js": "^2.1.4"
  },
  "peerDependencies": {
    "prosemirror-model": "^1.19.3",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.7.3",
    "prosemirror-view": "^1.31.4"
  },
  "devDependencies": {
    "@types/diff": "^5.0.3",
    "@types/jest": "^29.5.1",
    "jest": "^29.5.0",
    "prosemirror-model": "^1.19.3",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.7.3",
    "prosemirror-view": "^1.31.4",
    "rimraf": "^5.0.0",
    "rollup": "^3.29.2",
    "rollup-plugin-minification": "^0.2.0",
    "rollup-plugin-typescript2": "^0.35.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.2"
  }
}
